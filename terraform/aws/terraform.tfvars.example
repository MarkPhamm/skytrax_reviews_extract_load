# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

aws_region  = "us-east-1"
environment = "dev"

# After creating the Snowflake stage (Step 6), run DESC STAGE to get this ARN.
# Leave empty on first apply — fill in after Snowflake setup, then re-apply.
snowflake_iam_user_arn = ""
